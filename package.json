{
  "name": "omnixys-blog-service",
  "version": "1.0.1",
  "description": "Omnixys blog Service – zentrale Authentifizierungs- und Autorisierungskomponente (Keycloak, JWT, SSO).",
  "author": {
    "name": "Caleb Gyamfi",
    "email": "caleb@omnixys.com",
    "url": "https://omnixys.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/omnixys/omnixys-blog-service.git"
  },
  "bugs": {
    "url": "https://github.com/omnixys/omnixys-blog-service/issues"
  },
  "homepage": "https://omnixys.com",
  "license": "GPL-3.0-or-later",
  "type": "module",
  "private": false,
  "engines": {
    "node": ">=24.10.0",
    "pnpm": ">=10.19.0"
  },
  "scripts": {
    "clean": "rm -rf dist tsconfig.build.tsbuildinfo",
    "dev": "pnpm run clean && nest start --watch",
    "build": "nest build",
    "start": "nest start",
    "debug": "nest start --debug --watch",
    "prod": "node dist/main",
    "lint": "biome lint --files-ignore-unknown=true",
    "format": "biome format --write",
    "lint:fix": "biome lint . --write",
    "check": "biome check .",
    "check:fix": "biome check . --write --files-ignore-unknown=true",
    "prepare": "husky install",
    "release": "semantic-release",
    "prisma:gen": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio --schema prisma/schema.prisma",
    "prisma:seed": "tsx prisma/seed.ts",
    "prisma:push": "prisma db push",
    "prisma:pull": "prisma db pull",
    "prisma:reset:locale": "prisma migrate reset --force && prisma migrate dev && tsx prisma/seed.ts",
    "prisma:reset": "prisma migrate reset --force && prisma migrate dev && tsx prisma/seed.ts",
    "prisma:format": "pnpm prisma format && pnpm prisma validate && prisma generate"
  },
  "dependencies": {
    "@apollo/server": "^5.4.0",
    "@apollo/subgraph": "^2.13.1",
    "@as-integrations/fastify": "^3.1.0",
    "@fastify/compress": "^8.3.1",
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/rate-limit": "^10.3.0",
    "@js-temporal/polyfill": "^0.5.1",
    "@nestjs/apollo": "^13.2.4",
    "@nestjs/axios": "^4.0.1",
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.0.1",
    "@nestjs/graphql": "^13.2.4",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-fastify": "^11.1.16",
    "@nestjs/terminus": "^11.1.1",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/auto-instrumentations-node": "^0.71.0",
    "@opentelemetry/context-async-hooks": "^2.6.0",
    "@opentelemetry/exporter-prometheus": "^0.213.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.213.0",
    "@opentelemetry/resources": "^2.6.0",
    "@opentelemetry/sdk-node": "^0.213.0",
    "@prisma/adapter-pg": "^7.4.2",
    "@prisma/client": "^7.4.2",
    "@valkey/client": "^1.0.0",
    "cfonts": "^3.3.1",
    "dotenv": "^17.3.1",
    "fastify": "^5.8.2",
    "graphql": "^16.13.1",
    "jwks-rsa": "^4.0.1",
    "kafkajs": "^2.2.4",
    "passport-jwt": "^4.0.1",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "@commitlint/cli": "^20.4.3",
    "@commitlint/config-conventional": "^20.4.3",
    "@eslint/eslintrc": "latest",
    "@eslint/js": "latest",
    "@nestjs/cli": "^11.0.16",
    "@nestjs/schematics": "latest",
    "@nestjs/testing": "^11.0.1",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.6",
    "@semantic-release/npm": "^13.1.5",
    "@semantic-release/release-notes-generator": "^14.1.0",
    "@swc/cli": "^0.6.0",
    "@swc/core": "^1.10.7",
    "@tsconfig/node23": "^23.0.4",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.7",
    "@types/passport-jwt": "^4.0.1",
    "@types/supertest": "^6.0.2",
    "chalk": "latest",
    "depcheck": "^1.4.7",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^16.0.0",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "lint-staged": "^16.3.2",
    "prettier": "^3.4.2",
    "prisma": "^7.4.2",
    "semantic-release": "^25.0.3",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "biome check --write --files-ignore-unknown=true"
    ],
    "*.{json,css,md}": [
      "biome format --write"
    ]
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
